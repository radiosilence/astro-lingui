{
  "name": "astro-lingui",
  "version": "0.1.0",
  "description": "Astro integration for Lingui i18n with virtual modules and RTL support",
  "homepage": "https://github.com/radiosilence/astro-lingui#readme",
  "bugs": {
    "url": "https://github.com/radiosilence/astro-lingui/issues"
  },
  "license": "MIT",
  "author": "James Cleveland <jc@blit.cc>",
  "repository": {
    "type": "git",
    "url": "git://github.com/radiosilence/astro-lingui.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./locals": {
      "types": "./dist/locals.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown && cp src/locals.d.ts dist/locals.d.ts",
    "prepublishOnly": "npm run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/compiler": "^2.13.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.1",
    "@types/react": "^19.0.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.4.0",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "@lingui/cli": "^5.5.0",
    "@lingui/core": "^5.5.0",
    "@lingui/react": "^5.5.0",
    "@lingui/vite-plugin": "^5.5.0",
    "astro": "^5.0.0 || ^6.0.0",
    "react": "^19.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
